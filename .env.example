# ═══════════════════════════════════════════
# UNCLE CARTER PIPELINE — Environment Config
# Copy to .env.local and fill in your keys
# ═══════════════════════════════════════════

# REQUIRED: Supabase (free at supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# REQUIRED: Claude API (server-side only — never exposed to browser)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# REQUIRED: Access control — only this email domain can sign in
NEXT_PUBLIC_ALLOWED_DOMAIN=peekmedia.co

# OPTIONAL: Airtable sync (server-side only — never exposed to browser)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_TABLE=Stories
